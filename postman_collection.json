{
  "info": {
    "name": "GitHub Profile Analyzer API",
    "description": "Complete Postman collection for the GitHub Profile Analyzer backend service.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:24161", "type": "string" },
    { "key": "username", "value": "torvalds", "type": "string" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] },
        "description": "Check if the service is running"
      }
    },
    {
      "name": "Profiles",
      "item": [
        {
          "name": "Analyze Profile",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/profiles/analyze/{{username}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profiles", "analyze", "{{username}}"]
            },
            "description": "Fetch GitHub profile, compute insights, store in DB. Re-calling updates the record."
          }
        },
        {
          "name": "List All Profiles",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/profiles?page=1&limit=10&sort=activity_score&order=DESC",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profiles"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "sort", "value": "activity_score" },
                { "key": "order", "value": "DESC" }
              ]
            },
            "description": "Paginated list of all analyzed profiles"
          }
        },
        {
          "name": "Get Single Profile",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/profiles/{{username}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profiles", "{{username}}"]
            },
            "description": "Get a stored profile by GitHub username"
          }
        },
        {
          "name": "Delete Profile",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/profiles/{{username}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profiles", "{{username}}"]
            },
            "description": "Remove a profile from the database"
          }
        }
      ]
    }
  ]
}
